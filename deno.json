{
  "name": "@rick/tedasuke",
  "version": "0.3.0",
  "exports": {
    ".": "./mod.ts",
    "./cache": "./src/cache.ts"
  },
  "tasks": {
    "example": "deno run --allow-net --allow-env examples/basic-usage.ts",
    "test": "deno test --allow-net --allow-env",
    "check": "deno check **/*.ts",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "preflight": "deno fmt && deno check **/*.ts && deno lint && deno test --allow-net --allow-env",
    "publish:dry": "deno publish --dry-run"
  },
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "noImplicitThis": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictPropertyInitialization": true
  },
  "fmt": {
    "semiColons": true,
    "singleQuote": false
  },
  "lint": {
    "rules": {
      "tags": ["recommended"],
      "include": [
        "eqeqeq",
        "no-eval",
        "no-throw-literal"
      ]
    }
  },
  "publish": {
    "exclude": [
      ".git",
      ".github",
      ".claude",
      "examples",
      "tests",
      "docs",
      "CLAUDE.md"
    ]
  }
}
